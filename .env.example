# 环境变量示例配置
# 复制此文件为 .env.local 并填入你的配置

# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# RevenueCat 配置
REVENUECAT_API_KEY=your-revenuecat-api-key
REVENUECAT_IOS_API_KEY=your-ios-api-key
REVENUECAT_ANDROID_API_KEY=your-android-api-key

# 可选：企业版配置
TEAM_DEFAULT_FAIL_THRESHOLD=3
